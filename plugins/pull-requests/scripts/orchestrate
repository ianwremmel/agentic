#!/usr/bin/env bash
set -euo pipefail

# Unified entry point for PR automation scripts.
#
# Loads shared helpers from lib/ and subcommand implementations from
# subcommands/, then dispatches to the requested subcommand.
#
# Usage: scripts/orchestrate <subcommand> [args...]
#
# See ./CLAUDE.md for the layout, ./subcommands/CLAUDE.md for what each
# subcommand does, and ./lib/CLAUDE.md for the shared helpers.

SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Shared helpers (idempotent via load guards).
source "$SCRIPTS_DIR/lib/_retry"
source "$SCRIPTS_DIR/lib/gh-auth"
source "$SCRIPTS_DIR/lib/pr-state"
source "$SCRIPTS_DIR/lib/comments"
source "$SCRIPTS_DIR/lib/reviews"

# Subcommand implementations.
source "$SCRIPTS_DIR/subcommands/ready"
source "$SCRIPTS_DIR/subcommands/reply"
source "$SCRIPTS_DIR/subcommands/progress"
source "$SCRIPTS_DIR/subcommands/setup"
source "$SCRIPTS_DIR/subcommands/find-worktree"
source "$SCRIPTS_DIR/subcommands/react"
source "$SCRIPTS_DIR/subcommands/label"
source "$SCRIPTS_DIR/subcommands/start-pr"
source "$SCRIPTS_DIR/subcommands/poll"
source "$SCRIPTS_DIR/subcommands/review"
source "$SCRIPTS_DIR/subcommands/check-status"
source "$SCRIPTS_DIR/subcommands/debug"

main() {
  if [[ $# -lt 1 ]]; then
    echo "Error: subcommand required" >&2
    echo "Usage: scripts/orchestrate <subcommand> [args...]" >&2
    return 1
  fi

  local subcommand="$1"
  shift

  case $subcommand in
    progress)      cmd_progress "$@" ;;
    reply)         cmd_reply "$@" ;;
    ready)         cmd_ready "$@" ;;
    setup)         cmd_setup "$@" ;;
    find-worktree) cmd_find_worktree "$@" ;;
    react)         cmd_react "$@" ;;
    label)         cmd_label "$@" ;;
    start-pr)      cmd_start_pr "$@" ;;
    poll)          cmd_poll "$@" ;;
    review)        cmd_review "$@" ;;
    check-status)  cmd_check_status "$@" ;;
    debug)         cmd_debug "$@" ;;
    *)
      echo "Error: unknown subcommand '${subcommand}'" >&2
      echo "Usage: scripts/orchestrate <subcommand> [args...]" >&2
      return 1
      ;;
  esac
}

if [[ ${BASH_SOURCE[0]} == "${0}" ]]; then
  main "$@"
fi
