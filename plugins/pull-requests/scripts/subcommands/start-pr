# subcommands/start-pr - Create a new PR from the current branch: derive title, generate body, register in active-prs state.
# Sourced by ../orchestrate; defines functions for the `start-pr` subcommand.

SCRIPTS_DIR="${SCRIPTS_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
source "$SCRIPTS_DIR/lib/_retry"

ACTIVE_PRS_DIR="${ACTIVE_PRS_DIR:-/tmp/claude/project-state}"
ACTIVE_PRS_FILE="${ACTIVE_PRS_FILE:-${ACTIVE_PRS_DIR}/active-prs.json}"

# Derives a PR title from a branch name
# Strips date suffixes and ticket ID prefixes, converts hyphens to spaces
# Arguments:
#   $1 - branch_name
#   $2 - ticket_id (optional): If provided, prefix title with ticket ID
# Returns:
#   PR title string to stdout
derive_pr_title() {
  if [[ $# -lt 1 ]]; then
    echo "Error: derive_pr_title requires at least 1 argument" >&2
    return 2
  fi

  local branch_name="$1"
  local ticket_id="${2:-}"
  local slug="$branch_name"

  # Strip date suffix (e.g., -2026-03-17T021549)
  slug=$(printf '%s\n' "$slug" | sed 's/-[0-9]\{4\}-[0-9]\{2\}-[0-9]\{2\}T[0-9]\{6\}$//')

  # Strip ticket ID prefix (e.g., clc-539-)
  if [[ -n $ticket_id ]]; then
    local lower_ticket
    lower_ticket=$(printf '%s\n' "$ticket_id" | tr '[:upper:]' '[:lower:]')
    slug="${slug#"${lower_ticket}-"}"
  fi

  # Convert hyphens to spaces for readability
  slug="${slug//-/ }"

  # Capitalize first letter
  slug="$(printf '%s' "${slug:0:1}" | tr '[:lower:]' '[:upper:]')${slug:1}"

  if [[ -n $ticket_id ]]; then
    echo "${ticket_id}: ${slug}"
  else
    echo "$slug"
  fi
}

# Generates the initial PR body with progress block
# Arguments:
#   $1 - ticket_id (optional, pass "" for none)
#   $2 - ticket_url (optional, pass "" for none)
# Returns:
#   PR body text to stdout
generate_pr_body() {
  local ticket_id="${1:-}"
  local ticket_url="${2:-}"
  local body=""

  body+="## Summary"$'\n'
  body+="_Draft PR — implementation pending._"$'\n'
  body+=$'\n'

  if [[ -n $ticket_id && -n $ticket_url ]]; then
    body+="Resolves [${ticket_id}](${ticket_url})"$'\n'
    body+=$'\n'
  fi

  body+="## Progress"$'\n'
  body+="- [ ] Implementation"$'\n'
  body+="- [ ] CI passing (attempt 0/3)"$'\n'
  body+="- [ ] Code review requested"$'\n'
  body+="- [ ] Review feedback addressed (cycle 0/5)"$'\n'
  body+="- [ ] Merged"$'\n'
  body+=$'\n'

  body+="## Decisions"$'\n'
  body+="_No decisions recorded yet._"$'\n'
  body+=$'\n'

  body+="## Test plan"$'\n'
  body+="- [ ] Unit tests pass"$'\n'
  body+="- [ ] Lint passes"$'\n'
  body+="- [ ] Build succeeds"$'\n'
  body+=$'\n'

  local timestamp
  timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)

  local commit_scope="unknown"

  body+="<!-- clc-progress"$'\n'
  body+="phase: implementation"$'\n'
  body+="ci_fix_attempts: 0"$'\n'
  body+="review_cycles: 0"$'\n'
  body+="implementation_complete: false"$'\n'
  body+="commit_scope: ${commit_scope}"$'\n'
  body+="last_updated: ${timestamp}"$'\n'
  body+="watermark_review_id: 0"$'\n'
  body+="watermark_comment_id: 0"$'\n'
  body+="watermark_issue_comment_id: 0"$'\n'
  body+="-->"

  printf '%s\n' "$body"
}

# Appends a PR entry to active-prs.json atomically
# Arguments:
#   $1 - pr_number
#   $2 - branch_name
#   $3 - worktree_dir
#   $4 - ticket_id (optional, pass "" for none)
#   $5 - ticket_url (optional, pass "" for none)
# Returns:
#   0 on success
append_active_pr() {
  if [[ $# -lt 3 ]]; then
    echo "Error: append_active_pr requires at least 3 arguments" >&2
    return 2
  fi

  local pr_number="$1"
  local branch_name="$2"
  local worktree_dir="$3"
  local ticket_id="${4:-}"
  local ticket_url="${5:-}"

  mkdir -p "$ACTIVE_PRS_DIR"

  local existing="[]"
  if [[ -f $ACTIVE_PRS_FILE ]]; then
    existing=$(cat "$ACTIVE_PRS_FILE")
  fi

  local new_entry
  new_entry=$(jq -cn \
    --argjson pr_number "$pr_number" \
    --arg branch_name "$branch_name" \
    --arg worktree_dir "$worktree_dir" \
    --arg ticket_id "$ticket_id" \
    --arg ticket_url "$ticket_url" \
    '{pr_number: $pr_number, branch_name: $branch_name, worktree_dir: $worktree_dir, ticket_id: $ticket_id, ticket_url: $ticket_url}')

  local updated
  updated=$(printf '%s\n' "$existing" | jq --argjson entry "$new_entry" '. + [$entry]')

  # Atomic write: write to temp file, then move into place
  local tmp_file="${ACTIVE_PRS_FILE}.tmp"
  printf '%s\n' "$updated" > "$tmp_file"
  mv "$tmp_file" "$ACTIVE_PRS_FILE"
}

# Creates an empty commit, pushes, and creates a draft PR
# Arguments:
#   $1 - worktree_dir
#   --ticket-id ID (optional)
#   --ticket-url URL (optional)
# Returns:
#   JSON: {pr_number, pr_url, branch_name} to stdout
#   Exit 0 on success, non-zero on failure
cmd_start_pr() {
  if [[ $# -lt 1 ]]; then
    echo "Error: requires at least 1 argument" >&2
    echo "Usage: scripts/orchestrate start-pr <worktree_dir> [--ticket-id ID] [--ticket-url URL]" >&2
    return 1
  fi

  local worktree_dir="$1"
  shift

  local ticket_id=""
  local ticket_url=""

  while [[ $# -gt 0 ]]; do
    case $1 in
      --ticket-id)
        if [[ $# -lt 2 ]]; then
          echo "Error: --ticket-id requires a value" >&2
          return 1
        fi
        ticket_id="$2"
        shift 2
        ;;
      --ticket-url)
        if [[ $# -lt 2 ]]; then
          echo "Error: --ticket-url requires a value" >&2
          return 1
        fi
        ticket_url="$2"
        shift 2
        ;;
      *)
        echo "Error: unknown option '$1'" >&2
        return 1
        ;;
    esac
  done

  if [[ ! -d $worktree_dir ]]; then
    echo "Error: worktree directory does not exist: ${worktree_dir}" >&2
    return 1
  fi

  # Resolve to canonical absolute path so active-prs.json always stores absolute paths
  if ! worktree_dir=$(cd "$worktree_dir" && pwd -P); then
    echo "Error: failed to resolve worktree directory to a canonical path: ${worktree_dir}" >&2
    return 1
  fi

  # Get branch name from the worktree
  local branch_name
  branch_name=$(git -C "$worktree_dir" rev-parse --abbrev-ref HEAD)

  if [[ -z $branch_name || $branch_name == "HEAD" ]]; then
    echo "Error: could not determine branch name in ${worktree_dir}" >&2
    return 1
  fi

  # Create empty commit
  git -C "$worktree_dir" commit \
    --allow-empty \
    -m "chore: initial commit for draft PR" \
    >&2

  # Push to remote
  git -C "$worktree_dir" push \
    -u origin "$branch_name" \
    >&2

  # Derive PR title
  local title
  title=$(derive_pr_title "$branch_name" "$ticket_id")

  # Generate PR body
  local body
  body=$(generate_pr_body "$ticket_id" "$ticket_url")

  # Create draft PR — stdout captures the URL; stderr flows to caller naturally
  local pr_url
  pr_url=$(gh pr create \
    --head "$branch_name" \
    --draft \
    --title "$title" \
    --body "$body" \
    --repo "$(retry 3 5 gh repo view --json nameWithOwner --jq '.nameWithOwner')")

  # Extract PR number from URL
  # gh pr create outputs the PR URL to stdout
  local pr_number
  pr_number=$(printf '%s\n' "$pr_url" | grep -oE '[0-9]+$')

  if [[ -z $pr_number ]]; then
    echo "Error: failed to create draft PR — unexpected output: ${pr_url}" >&2
    return 1
  fi

  # Append to active-prs.json
  append_active_pr "$pr_number" "$branch_name" "$worktree_dir" "$ticket_id" "$ticket_url"

  # Output result JSON
  jq -cn \
    --argjson pr_number "$pr_number" \
    --arg pr_url "$pr_url" \
    --arg branch_name "$branch_name" \
    '{"pr_number":$pr_number,"pr_url":$pr_url,"branch_name":$branch_name}'
}
